# Server
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<db> (alias)
PORT=5000
NODE_ENV=development

# Auth
JWT_SECRET=change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Email
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-app-password

# Payments: Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Payments: PhonePe
MERCHANT_ID=your_phonepe_merchant_id
SALT_KEY=your_phonepe_salt_key
SALT_INDEX=1

# Hotel info
HOTEL_UPI_ID=your-upi-id@bank
HOTEL_UPI_NAME=Hotel Sai International
HOTEL_CONTACT_EMAIL=info@example.com
HOTEL_SUPPORT_PHONE=+91 00000 00000
HOTEL_WHATSAPP_NUMBER=910000000000

# Frontend / CORS
FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,https://your-domain.com

# Frontend build (Vite)
VITE_API_BASE_URL=https://your-backend.example.com
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
DISABLE_HMR=false
